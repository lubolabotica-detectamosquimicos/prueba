
// ── ID DE USUARIO LOCAL ──────────────────────────────────────
function getUserId() {
  let uid = localStorage.getItem('lubo_uid');
  if (!uid) { uid = 'u_' + Date.now() + '_' + Math.random().toString(36).slice(2,8); localStorage.setItem('lubo_uid', uid); }
  return uid;
}
function getUserName() { return localStorage.getItem('lubo_nombre') || 'Usuario'; }

// ── SEMÁFORO SUPERIOR: activar bola correspondiente ──────────
function activarSemaforo(clsf) {
  // Reset todos
  ['ball-rojo','ball-amber','ball-verde'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('active');
  });
  ['sem-rojo','sem-amber','sem-verde'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('active');
  });
  // Activar el correspondiente
  const mapa = { rojo: ['ball-rojo','sem-rojo'], amarillo: ['ball-amber','sem-amber'], verde: ['ball-verde','sem-verde'] };
  if (mapa[clsf]) {
    mapa[clsf].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.add('active');
    });
  }
}

// ── STATS LOCALES ────────────────────────────────────────────
function getStatsLocal() {
  try { return JSON.parse(localStorage.getItem('lubo_stats') || '{"usos":0,"analisis":[]}'); }
  catch { return { usos: 0, analisis: [] }; }
}
function saveStatsLocal(data) {
  localStorage.setItem('lubo_stats', JSON.stringify(data));
}
function registrarAnalisisLocal(resultado) {
  const stats = getStatsLocal();
  stats.usos = (stats.usos || 0) + 1;
  if (!stats.analisis) stats.analisis = [];
  stats.analisis.unshift({
    fecha: new Date().toLocaleString('es-CO'),
    clasificacion: resultado.clasificacion_sugerida || 'verde',
    total_ingredientes: resultado.ingredientes?.length || 0,
    quimicos: resultado.coincidencias || [],
    naturales_count: resultado.naturales?.length || 0
  });
  // Guardar solo los últimos 20
  stats.analisis = stats.analisis.slice(0, 20);
  saveStatsLocal(stats);
}

// ── PANTALLA MIS STATS ───────────────────────────────────────
function renderStats() {
  const stats = getStatsLocal();
  const resumen = document.getElementById('stats-resumen');
  const lista = document.getElementById('stats-lista');
  if (!resumen || !lista) return;

  resumen.innerHTML = `
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px">
      <div class="stats-card">
        <div class="stats-label">Total escaneos</div>
        <div class="stats-val">${stats.usos || 0}</div>
      </div>
      <div class="stats-card">
        <div class="stats-label">Último análisis</div>
        <div class="stats-val" style="font-size:13px;font-weight:400">${stats.analisis?.[0]?.fecha || '—'}</div>
      </div>
    </div>`;

  if (!stats.analisis?.length) {
    lista.innerHTML = '<div class="placeholder"><svg viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg><p>Aún no has hecho ningún análisis</p><small>Escanea la etiqueta de un producto para empezar</small></div>';
    return;
  }

  const colores = { rojo: '#e24b4a', amarillo: '#ef9f27', verde: '#639922' };
  const emojis = { rojo: '🚫', amarillo: '⚡', verde: '✅' };

  lista.innerHTML = '<div style="font-size:11px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3);margin-bottom:8px">Historial de análisis</div>' +
    stats.analisis.map(a => `
      <div style="background:var(--surface);border:1px solid var(--border);border-left:3px solid ${colores[a.clasificacion]||'#9e9b94'};border-radius:var(--r-md);padding:10px 12px;margin-bottom:6px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px">
          <span style="font-size:12px;font-weight:500">${emojis[a.clasificacion]||'•'} ${a.clasificacion==='rojo'?'NO CONSUMIR':a.clasificacion==='amarillo'?'PRECAUCIÓN':'PRODUCTO LIMPIO'}</span>
          <span style="font-size:10px;color:var(--text-3)">${a.fecha}</span>
        </div>
        <div style="font-size:11px;color:var(--text-3)">${a.total_ingredientes} ingredientes leídos · ${a.quimicos.length} químicos detectados · ${a.naturales_count} naturales</div>
        ${a.quimicos.length>0?`<div style="margin-top:5px;font-size:10px;color:#e24b4a">${a.quimicos.slice(0,3).join(', ')}${a.quimicos.length>3?' +más…':''}</div>`:''}
      </div>`).join('');
}

