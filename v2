function filtrar() {
  const q = document.getElementById('si').value.toLowerCase();
  if (!q && !FA_chip) { document.getElementById('rl').innerHTML = ''; return; }
  renderL(DB.filter(i => (i.nombre.toLowerCase().includes(q) || i.productos.toLowerCase().includes(q)) && (FA === 'todos' || i.semaforo === FA)));
}
function renderL(it) {
  const l = document.getElementById('rl');
  if (!it.length) { l.innerHTML = '<div class="empty"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6M9 9l6 6"/></svg><p>Sin resultados</p></div>'; return; }
  l.innerHTML = it.map(q => `<div class="q-card" onclick="det('${q.nombre.replace(/'/g,"\\'")}')"><div class="q-dot" style="background:${CM[q.semaforo]}"></div><div class="q-body"><div class="q-name">${q.nombre}<span class="badge badge-${q.semaforo[0]}">${q.semaforo==='rojo'?'⚠ Peligroso':q.semaforo==='amarillo'?'⚡ Precaución':'✓ Limpio'}</span></div><div style="font-size:11px;color:var(--text-3);margin-top:2px">${q.uso}${q.nocividad!==null?' · '+q.nocividad+'%':''}</div>${q.riesgo!=='Sin información'?`<div style="font-size:11px;color:var(--text-2);margin-top:2px">${q.riesgo}</div>`:''}</div></div>`).join('');
