const FORMSPREE_URL = 'https://formspree.io/f/mnjrknka';
function mostrarPopup() {
  const e = localStorage.getItem('lubo_popup');
  if (e === 'listo') return;
  if (!e) localStorage.setItem('lubo_popup', 'visto1');
  setTimeout(() => { document.getElementById('popup-overlay').style.display = 'flex'; }, 2000);
}
async function enviarPopup() {
  const nombre = document.getElementById('popup-nombre').value.trim();
  const email = document.getElementById('popup-email').value.trim();
  const uso = document.getElementById('popup-uso').value;
  const acepto = document.getElementById('popup-acepto').checked;
  if (!email) { alert('Por favor ingresa tu email.'); return; }
  if (!acepto) { alert('Por favor acepta recibir novedades.'); return; }
  const btn = document.getElementById('popup-btn');
  btn.textContent = 'Enviando...'; btn.disabled = true;
  try {
    const res = await fetch(FORMSPREE_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ nombre: nombre || 'Sin nombre', email, fecha: new Date().toLocaleDateString('es-CO'), zona: Intl.DateTimeFormat().resolvedOptions().timeZone || 'Desconocido', uso: uso || 'No especificado' })
    });
    if (!res.ok) { btn.textContent = 'Empezar gratis →'; btn.disabled = false; alert('Hubo un error. Intenta de nuevo.'); return; }
  } catch { btn.textContent = 'Empezar gratis →'; btn.disabled = false; alert('Error de conexión. Intenta de nuevo.'); return; }
  if (nombre) localStorage.setItem('lubo_nombre', nombre);
  localStorage.setItem('lubo_popup', 'listo');
  document.getElementById('popup-overlay').style.display = 'none';
}
function saltarPopup() {
  if (localStorage.getItem('lubo_popup') === 'visto1') localStorage.setItem('lubo_popup', 'listo');
  document.getElementById('popup-overlay').style.display = 'none';
}
mostrarPopup();

