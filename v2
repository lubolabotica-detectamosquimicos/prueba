let vids2 = null;
async function toggleCam() {
  if (vids2) { stopCamMain(); return; }
  try {
    vids2 = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment', width: { ideal: 1920 }, height: { ideal: 1080 } } });
    document.getElementById('vid2').srcObject = vids2;
    document.getElementById('vid-wrap2').style.display = 'block';
    document.getElementById('btn-cam').innerHTML = '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:white;fill:none;stroke-width:2"><line x1="1" y1="1" x2="23" y2="23"/><path d="M21 21H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3m3-3h6l2 3h4a2 2 0 0 1 2 2v9.34"/></svg> Detener cámara';
  } catch { alert('No se pudo acceder a la cámara. Usa "Galería / Subir foto" en su lugar.'); }
}
function stopCamMain() {
  if (vids2) { vids2.getTracks().forEach(t => t.stop()); vids2 = null; }
  document.getElementById('vid-wrap2').style.display = 'none';
  document.getElementById('btn-cam').innerHTML = '<svg viewBox="0 0 24 24" style="width:22px;height:22px;stroke:white;fill:none;stroke-width:2"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg> Escanear ingredientes';
}
function capturarMain() {
  const v = document.getElementById('vid2'), c = document.getElementById('cnv2');
  c.width = v.videoWidth; c.height = v.videoHeight;
  c.getContext('2d').drawImage(v, 0, 0);
  showPrevMain(c.toDataURL('image/jpeg', 0.95));
  stopCamMain();
}
function loadImgMain(e) {
  const f = e.target.files[0]; if (!f) return;
  const r = new FileReader();
  r.onload = ev => {
    const img = new Image();
    img.onload = () => {
      const MAX = 2048;
      let w = img.width, h = img.height;
      if (w > MAX || h > MAX) { const s = Math.min(MAX/w, MAX/h); w = Math.round(w*s); h = Math.round(h*s); }
      const c = document.getElementById('cnv2');
      c.width = w; c.height = h;
      c.getContext('2d').drawImage(img, 0, 0, w, h);
      showPrevMain(c.toDataURL('image/jpeg', 0.95));
    };
    img.src = ev.target.result;
  };
  r.readAsDataURL(f); e.target.value = '';
}
function showPrevMain(url) {
  document.getElementById('prev-img2').src = url;
  document.getElementById('prev-wrap2').style.display = 'block';
  document.getElementById('vid-wrap2').style.display = 'none';
  document.getElementById('cb-main').innerHTML = '';
  // Reset semáforo al mostrar nueva imagen
  activarSemaforo(null);
}
function resetCamMain() {
  document.getElementById('prev-wrap2').style.display = 'none';
  document.getElementById('cb-main').innerHTML = '';
  activarSemaforo(null);
}

// ── ANALIZAR CON IA ──────────────────────────────────────────
async function analizarImgMain() {
  const img = document.getElementById('prev-img2'), btn = document.getElementById('btn-ai2');
  btn.disabled = true;
  btn.innerHTML = '<span class="lds"><span></span><span></span><span></span></span> Analizando...';
  document.getElementById('cb-main').innerHTML = '<div style="text-align:center;padding:1.5rem;color:var(--text-3)"><span class="lds"><span></span><span></span><span></span></span><div style="margin-top:8px;font-size:12px">La IA está leyendo los ingredientes...</div></div>';
  try {
    const b64 = img.src.split(',')[1];
    const mediaType = img.src.split(';')[0].split(':')[1] || 'image/jpeg';
    const res = await fetch('/api/analizar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ imageBase64: b64, mediaType, userId: getUserId(), userName: getUserName() })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Error del servidor');
    mostrarResMain(data);
  } catch (e) {
    document.getElementById('cb-main').innerHTML = `<div style="padding:1rem;background:#fff8f0;border-radius:10px;font-size:13px;color:var(--text-2);line-height:1.6"><b>No se pudo leer bien la imagen.</b><br>Consejos:<br>• 🔍 Toca la imagen para ampliarla y verifica legibilidad<br>• 📸 Toma foto más cercana con buena iluminación<br>• 🔆 Evita reflejos o sombras sobre el texto<br>• 📝 Asegúrate que los ingredientes sean visibles</div>`;
  }
  btn.disabled = false;
  btn.innerHTML = '<svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:white;fill:none;stroke-width:2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg> Analizar con IA';
}

// ── MOSTRAR RESULTADOS ───────────────────────────────────────
function mostrarResMain(p) {
  // Imagen no legible
  if (p.error === 'imagen_no_legible' || (!p.ingredientes?.length && !p.coincidencias?.length)) {
    document.getElementById('cb-main').innerHTML = '<div style="padding:1rem;background:#fff8f0;border-radius:10px;font-size:13px;color:var(--text-2);line-height:1.6"><b>No se pudo leer bien la imagen.</b><br>Consejos:<br>• 🔍 Toca la imagen para ampliarla<br>• 📸 Toma foto más cercana con buena iluminación<br>• 🔆 Evita reflejos o sombras</div>';
    return;
  }

  const total = p.ingredientes?.length || 0;
  const coincidenciasRaw = p.coincidencias || [];
  const naturales = p.naturales || [];
  const sinteticos = p.sinteticos_desconocidos || [];

  // Cruzar coincidencias con la base de datos para obtener info completa
  const coins = coincidenciasRaw.map(n => {
    // Buscar en DB por nombre exacto o parcial
    return DB.find(q =>
      q.nombre.toLowerCase() === n.toLowerCase() ||
      q.nombre.toLowerCase().includes(n.toLowerCase()) ||
      n.toLowerCase().includes(q.nombre.toLowerCase().split(' ')[0])
    );
  }).filter(Boolean);
  const unicas = [...new Map(coins.map(q => [q.nombre, q])).values()];
  const rojos = unicas.filter(q => q.semaforo === 'rojo');
  const amars = unicas.filter(q => q.semaforo === 'amarillo');

  // REGLA SEMÁFORO:
  // ROJO: si hay 1+ químico con nocividad > 30, o si el % nocivos > 30
  const porcentajeNocivos = total > 0 ? (coincidenciasRaw.length / total) * 100 : 0;
  let clsf = p.clasificacion_sugerida || 'verde';
  if (rojos.length > 0 || porcentajeNocivos > 30) clsf = 'rojo';
  else if (amars.length > 0 || coincidenciasRaw.length > 0) clsf = 'amarillo';

  // Activar semáforo superior
  activarSemaforo(clsf);

  // Registrar en stats locales
  registrarAnalisisLocal({ ...p, clasificacion_sugerida: clsf });

  // ── Construir HTML de resultados ──
  let html = '';

  // Alerta NO CONSUMIR
  if (clsf === 'rojo') {
    html += '<div class="no-consumir">🚫 NO CONSUMIR — Contiene químicos peligrosos</div>';
  }

  // Resumen
  if (unicas.length > 0) {
    html += `<div style="font-size:13px;font-weight:500;color:var(--text);margin-bottom:9px">⚠ ${unicas.length} químico${unicas.length > 1 ? 's' : ''} detectado${unicas.length > 1 ? 's' : ''} en ${total} ingredientes leídos</div>`;
  } else {
    html += `<div style="font-size:13px;font-weight:500;color:var(--green-dark);margin-bottom:9px">✅ Producto limpio — ${total} ingredientes leídos, ninguno en lista de riesgo</div>`;
  }

  html += '<div class="finds">';

  // Químicos peligrosos (rojo)
  rojos.forEach(q => {
    html += `<div class="fi fi-r"><div class="fi-dot" style="background:#ff6161"></div><div class="fi-body"><div class="fi-name">⚠ ${q.nombre}</div><div class="fi-risk">${q.riesgo !== 'Sin información' ? q.riesgo : 'Nocividad: ' + q.nocividad + '%'} · ${q.uso}</div></div></div>`;
  });

  // Químicos precaución (amarillo)
  amars.forEach(q => {
    html += `<div class="fi fi-a"><div class="fi-dot" style="background:#ebb414"></div><div class="fi-body"><div class="fi-name">⚡ ${q.nombre}</div><div class="fi-risk">${q.riesgo !== 'Sin información' ? q.riesgo : 'Nocividad: ' + q.nocividad + '%'} · ${q.uso}</div></div></div>`;
  });

  // Ingredientes naturales (plegable)
  if (naturales.length > 0) {
    html += `<div class="fi fi-v" style="cursor:pointer" onclick="toggleList(this)">
      <div class="fi-dot" style="background:#53bb26"></div>
      <div class="fi-body">
        <div class="fi-name">🌿 ${naturales.length} ingrediente${naturales.length > 1 ? 's' : ''} natural${naturales.length > 1 ? 'es' : ''} <span style="font-size:10px;color:var(--text-3)">(toca para ver)</span></div>
        <div class="ing-list">${naturales.join(' · ')}</div>
      </div>
    </div>`;
  }

  // Ingredientes sintéticos no nocivos (plegable)
  if (sinteticos.length > 0) {
    html += `<div class="fi fi-n" style="cursor:pointer" onclick="toggleList(this)">
      <div class="fi-dot" style="background:#9e9b94"></div>
      <div class="fi-body">
        <div class="fi-name">🔬 ${sinteticos.length} sintético${sinteticos.length > 1 ? 's' : ''} (no en lista nociva) <span style="font-size:10px;color:var(--text-3)">(toca para ver)</span></div>
        <div class="ing-list">${sinteticos.join(' · ')}</div>
      </div>
    </div>`;
  }

  html += '</div>';

  // Nota de porcentaje si aplica
  if (porcentajeNocivos > 0) {
    html += `<div style="margin-top:8px;font-size:11px;color:var(--text-3);text-align:center">${coincidenciasRaw.length} de ${total} ingredientes están en lista de riesgo (${Math.round(porcentajeNocivos)}%)</div>`;
  }

  document.getElementById('cb-main').innerHTML = html;
}

function toggleList(el) {
  const list = el.querySelector('.ing-list');
  if (list) list.classList.toggle('open');
}

