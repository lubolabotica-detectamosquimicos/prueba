// Serverless: Google Sheets CSV + Gemini Vision en UNA sola llamada
// REQUISITO: el Sheet debe ser publico (Compartir > Cualquiera > Lector)
const SHEET_ID = '1QLmkn8hfq_vkBv3IcaJNRI_ly6f5HorZ';
const GID      = '2117305422';

function parseCSV(text) {
  var rows = [];
  var lines = text.split('\n');
  for (var li = 0; li < lines.length; li++) {
    var line = lines[li];
    if (!line.trim()) continue;
    var cols = [], cur = '', inQ = false;
    for (var i = 0; i < line.length; i++) {
      if (line[i] === '"')           { inQ = !inQ; continue; }
      if (line[i] === ',' && !inQ)   { cols.push(cur.trim()); cur = ''; continue; }
      cur += line[i];
    }
    cols.push(cur.trim());
    rows.push(cols);
  }
  return rows;
}

export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin',  '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST')   return res.status(405).json({ error: 'Method not allowed' });

  try {
    var body = req.body;
    if (!body.imageBase64) return res.status(400).json({ error: 'No se recibio imagen.' });

    // 1 — Cargar lista de quimicos desde Google Sheets (exportacion CSV publica)
    var csvUrl   = 'https://docs.google.com/spreadsheets/d/' + SHEET_ID + '/export?format=csv&gid=' + GID;
    var sheetRes = await fetch(csvUrl);
    if (!sheetRes.ok) throw new Error('No se pudo cargar el Sheet. Asegurate de que sea publico (vista).');

    var rows      = parseCSV(await sheetRes.text());
    var chemicals = rows.slice(1).map(function(r) {
      return {
        nombre:        (r[0] || '').trim(),
        nocividad:     parseFloat((r[1] || '0').replace('%','').replace(',','.')),
        clasificacion: (r[2] || '').trim()
      };
    }).filter(function(c) { return c.nombre.length > 0; });

    if (!chemicals.length) throw new Error('Lista de quimicos vacia o inaccesible.');

    // 2 — Construir lista para el prompt (sin template literals)
    var chemicalsList = chemicals.map(function(c) {
      return '- ' + c.nombre + ' | Nocividad: ' + c.nocividad + '% | Clasificacion: ' + c.clasificacion;
    }).join('\n');

    // 3 — Llamar a Gemini Vision API
    var GEMINI_URL = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=' + process.env.GEMINI_API_KEY;

    var prompt =
      'Eres un analizador de ingredientes de productos de consumo.\n\n' +
      'TAREA: Lee los ingredientes visibles en esta imagen y comparalos UNICAMENTE con la siguiente lista. NO uses conocimiento externo ni bases de datos propias.\n\n' +
      'LISTA DE QUIMICOS (fuente unica autorizada):\n' + chemicalsList + '\n\n' +
      'INSTRUCCIONES:\n' +
      '1. Extrae TODOS los ingredientes visibles en la imagen.\n' +
      '2. Compara cada uno SOLO contra la lista anterior.\n' +
      '3. Reporta solo coincidencias encontradas en esa lista.\n' +
      '4. Si un ingrediente NO esta en la lista, ignoralo.\n' +
      '5. NO agregues quimicos que no esten en la lista provista.\n\n' +
      'Responde UNICAMENTE con este JSON, sin texto adicional:\n' +
      '{\n' +
      '  "ingredientesLeidos": ["nombre1", "nombre2"],\n' +
      '  "coincidencias": [\n' +
      '    { "nombreDetectado": "texto imagen", "nombreLista": "texto lista", "nocividad": 45, "clasificacion": "texto" }\n' +
      '  ],\n' +
      '  "error": null\n' +
      '}';

    var geminiBody = {
      contents: [{
        parts: [
          { text: prompt },
          { inline_data: { mime_type: body.mimeType || 'image/jpeg', data: body.imageBase64 } }
        ]
      }],
      generationConfig: { temperature: 0.1, maxOutputTokens: 1500 }
    };

    var gRes = await fetch(GEMINI_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(geminiBody)
    });

    if (!gRes.ok) {
      var errData = await gRes.json().catch(function() { return {}; });
      throw new Error('Gemini error: ' + JSON.stringify(errData));
    }

    var gData  = await gRes.json();
    var parts  = ((gData.candidates || [])[0] || {}).content && gData.candidates[0].content.parts;
    var rawTxt = parts ? parts[0].text : '';
    var clean  = rawTxt.replace(/```json|```/g, '').trim();
    var result = JSON.parse(clean);

    return res.status(200).json(result);

  } catch (err) {
    console.error('analyze error:', err.message);
    return res.status(500).json({ error: err.message || 'Error al analizar.', ingredientesLeidos: [], coincidencias: [] });
  }
}
