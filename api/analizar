/**
 * API: /api/analizar
 * 
 * Analyzes product ingredient labels using Google Gemini Vision
 * Classifies ingredients using ONLY the external Google Sheets database
 * No internal databases - everything comes from the external source
 */

const { GoogleGenerativeAI } = require('@google/generative-ai');

// Initialize Gemini
const genAI = new GoogleGenerativeAI(process.env.GOOGLE_API_KEY);

// Google Sheets URL
const GOOGLE_SHEETS_CSV_URL = 'https://docs.google.com/spreadsheets/d/1QLmkn8hfq_vkBv3IcaJNRI_ly6f5HorZ/export?format=csv&gid=2117305422';

/**
 * Fetch and parse Google Sheets database
 */
async function obtenerBaseDatos() {
    try {
        const response = await fetch(GOOGLE_SHEETS_CSV_URL);
        const csv = await response.text();
        return parsearCSV(csv);
    } catch (error) {
        console.error('Error fetching database:', error);
        return [];
    }
}

/**
 * Parse CSV to ingredients array
 */
function parsearCSV(csv) {
    const lines = csv.trim().split('\n');
    const ingredientes = [];
    
    // Skip header
    for (let i = 1; i < lines.length; i++) {
        const parts = parsearLineaCSV(lines[i]);
        
        if (parts.length >= 4) {
            const categoria = parts[0].trim().toUpperCase();
            const nombre = parts[1].trim();
            const motivo = parts[2].trim();
            const nocividad = parseInt(parts[3]) || 0;
            
            if (['ROJO', 'AMARILLO', 'VERDE'].includes(categoria) && nombre) {
                ingredientes.push({
                    categoria,
                    nombre,
                    motivo,
                    nocividad
                });
            }
        }
    }
    
    return ingredientes;
}

/**
 * Parse CSV line handling quotes and commas
 */
function parsearLineaCSV(line) {
    const result = [];
    let current = '';
    let inQuotes = false;
    
    for (let i = 0; i < line.length; i++) {
        const char = line[i];
        
        if (char === '"') {
            inQuotes = !inQuotes;
        } else if (char === ',' && !inQuotes) {
            result.push(current);
            current = '';
        } else {
            current += char;
        }
    }
    
    result.push(current);
    return result;
}

/**
 * Extract text from image using Gemini Vision
 */
async function extraerTextoDeImagen(base64Image) {
    try {
        const model = genAI.getGenerativeModel({ model: 'gemini-1.5-flash' });
        
        const prompt = `
IMPORTANTE: Extrae SOLO la lista de ingredientes de esta etiqueta de producto.
Retorna UN ÚNICO objeto JSON válido con este formato exacto:
{
  "ingredientes": ["nombre1", "nombre2", "nombre3"],
  "confianza": 0.95
}

Notas:
- Incluye TODOS los ingredientes visibles
- Usa nombres en ESPAÑOL cuando sea posible
- No agregues explicaciones, solo JSON
- Si no puedes ver ingredientes, retorna lista vacía: {"ingredientes": [], "confianza": 0}
`;

        const response = await model.generateContent([
            {
                inlineData: {
                    mimeType: 'image/jpeg',
                    data: base64Image
                }
            },
            prompt
        ]);
        
        const text = response.response.text();
        
        // Try to parse JSON from response
        const jsonMatch = text.match(/\{[\s\S]*\}/);
        if (jsonMatch) {
            return JSON.parse(jsonMatch[0]);
        }
        
        return { ingredientes: [], confianza: 0 };
    } catch (error) {
        console.error('Error extracting text:', error);
        return { ingredientes: [], confianza: 0 };
    }
}

/**
 * Classify ingredients against database
 */
function clasificarIngredientes(nombresIngredientes, baseDatos) {
    const resultados = [];
    const ingredientesNoEncontrados = [];
    
    for (const nombre of nombresIngredientes) {
        const termino = nombre.toLowerCase().trim();
        
        // Search in database
        const encontrado = baseDatos.find(ing =>
            ing.nombre.toLowerCase().includes(termino) ||
            termino.includes(ing.nombre.toLowerCase())
        );
        
        if (encontrado) {
            resultados.push({
                nombre: encontrado.nombre,
                categoria: encontrado.categoria,
                nocividad: encontrado.nocividad,
                motivo: encontrado.motivo || ''
            });
        } else {
            ingredientesNoEncontrados.push(nombre);
        }
    }
    
    return { clasificados: resultados, noEncontrados: ingredientesNoEncontrados };
}

/**
 * Determine overall semaforo color based on ingredients
 */
function determinarSemaforo(ingredientes) {
    if (ingredientes.length === 0) {
        return { categoria: 'VERDE', mensaje: 'Sin ingredientes detectados' };
    }
    
    // Check for ROJO (>30% nocividad or explicit ROJO category)
    const tieneRojo = ingredientes.some(ing => 
        ing.categoria === 'ROJO' || ing.nocividad > 30
    );
    
    if (tieneRojo) {
        return { 
            categoria: 'ROJO', 
            mensaje: 'Contiene químicos nocivos (>30% nocividad)' 
        };
    }
    
    // Check for AMARILLO
    const tieneAmarillo = ingredientes.some(ing => ing.categoria === 'AMARILLO');
    
    if (tieneAmarillo) {
        return { 
            categoria: 'AMARILLO', 
            mensaje: 'Contiene ingredientes que requieren precaución' 
        };
    }
    
    // All VERDE
    return { 
        categoria: 'VERDE', 
        mensaje: 'Todos los ingredientes son seguros' 
    };
}

/**
 * Main handler
 */
export default async function handler(req, res) {
    // CORS headers
    res.setHeader('Access-Control-Allow-Origin', '*');
    res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
    res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
    
    if (req.method === 'OPTIONS') {
        return res.status(200).end();
    }
    
    if (req.method !== 'POST') {
        return res.status(405).json({ error: 'Method not allowed' });
    }
    
    try {
        const { imagen } = req.body;
        
        if (!imagen) {
            return res.status(400).json({ error: 'No image provided' });
        }
        
        // Extract base64 from data URL
        const base64Image = imagen.includes('base64,') 
            ? imagen.split('base64,')[1] 
            : imagen;
        
        console.log('1. Extrayendo texto de imagen...');
        const { ingredientes: nombresIngredientes, confianza } = await extraerTextoDeImagen(base64Image);
        
        console.log(`2. Ingredientes extraídos: ${nombresIngredientes.length}, Confianza: ${confianza}`);
        
        // Fetch database from Google Sheets
        console.log('3. Cargando base de datos desde Google Sheets...');
        const baseDatos = await obtenerBaseDatos();
        console.log(`4. Base de datos cargada: ${baseDatos.length} ingredientes`);
        
        // Classify ingredients
        console.log('5. Clasificando ingredientes...');
        const { clasificados, noEncontrados } = clasificarIngredientes(nombresIngredientes, baseDatos);
        
        // Determine semaforo
        const semaforo = determinarSemaforo(clasificados);
        
        // Log statistics
        console.log(`6. Análisis completado:`);
        console.log(`   - Clasificados: ${clasificados.length}`);
        console.log(`   - No encontrados: ${noEncontrados.length}`);
        console.log(`   - Semáforo: ${semaforo.categoria}`);
        
        // Return response
        return res.status(200).json({
            success: true,
            ingredientes: clasificados,
            noEncontrados,
            semaforo,
            confianza,
            timestamp: new Date().toISOString(),
            bdVersion: baseDatos.length
        });
        
    } catch (error) {
        console.error('Analysis error:', error);
        return res.status(500).json({ 
            error: 'Error during analysis',
            details: error.message 
        });
    }
}
