export default async function handler(req, res) {
  if (req.method !== 'POST') {
    return res.status(405).json({ error: 'Método no permitido' });
  }

  const apiKey = process.env.GEMINI_API_KEY;
  if (!apiKey) {
    return res.status(500).json({ error: 'API key no configurada en el servidor' });
  }

  try {
    const { imageBase64, mediaType } = req.body;
    if (!imageBase64) {
      return res.status(400).json({ error: 'Se requiere una imagen' });
    }

    // Lista de químicos nocivos
    const DB_QUIMICOS = [
      "Bromato de potasio","Nitratos y nitritos","Aceites parcialmente hidrogenados",
      "BHA / BHT","Bisfenol A (BPA)","Aluminio (sales)","Tartrazina",
      "Colorantes artificiales (Amarillo 5, Azul 1, Rojo 40)","Perclorato",
      "Glutamato monosódico","Eritrosina (Rojo N°3)","Jarabe de maíz de alta fructosa",
      "Azúcar","Propionato","Carragenina","Compuestos perfluorados (PFOA, PFOS)",
      "Cloro y triclorometano","Benzoato de sodio","Propylene glycol",
      "Peroxido de Benzoilo","Plomo","Mercurio","Formaldehido","Ftalatos",
      "Alquitrán de hulla","Tolueno","Dioxano (1,4-dioxane)","Triclosán",
      "Aluminio (clorhidrato)","DEA/TEA/MEA","Etanolaminas (MEA, TEA, DEA)",
      "Resorcinol","Parfum","Oxibenzona y avobenzona","Metilparabeno",
      "Propilparabeno","Bencilparabeno","Etilparabeno","Butilparabeno",
      "Microplásticos (polietileno, nylon)","Laurate sulphate","Siliconas PEG/PPG",
      "Paraffinum","Sodium","Ammonium","Siliconas","Diacetileno"
    ];

    const prompt = `Eres un experto analizador de etiquetas de ingredientes de productos de consumo (alimentos y cosméticos).

Analiza esta imagen de etiqueta y sigue estas instrucciones exactas:

1. LEE todos los ingredientes visibles en el texto de la imagen, en cualquier idioma (español, inglés, latín científico, francés, etc.)
2. COMPARA cada ingrediente leído con esta lista de químicos nocivos: ${DB_QUIMICOS.join(', ')}
3. IDENTIFICA cuáles ingredientes de la imagen coinciden (exacta o parcialmente) con los de la lista de químicos nocivos
4. CLASIFICA los ingredientes restantes como naturales o sintéticos según tu conocimiento

Responde ÚNICAMENTE con este JSON (sin markdown, sin texto adicional):
{
  "ingredientes": ["lista completa de ingredientes leídos en la imagen"],
  "coincidencias": ["nombres EXACTOS de la lista de químicos nocivos que encontraste"],
  "naturales": ["ingredientes que son claramente de origen natural"],
  "sinteticos_desconocidos": ["ingredientes sintéticos que no están en la lista de nocivos pero no son naturales"]
}

Si la imagen no es legible o no contiene ingredientes, responde:
{"error": "imagen_no_legible", "ingredientes": [], "coincidencias": [], "naturales": [], "sinteticos_desconocidos": []}`;

    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        contents: [{
          parts: [
            { inline_data: { mime_type: mediaType || 'image/jpeg', data: imageBase64 } },
            { text: prompt }
          ]
        }],
        generationConfig: {
          temperature: 0.1,
          topP: 0.8,
          maxOutputTokens: 2048
        }
      })
    });

    const data = await response.json();
    if (!response.ok) {
      return res.status(response.status).json({ error: data.error?.message || 'Error de API' });
    }

    const text = data.candidates[0].content.parts[0].text;
    const clean = text.replace(/```json|```/g, '').trim();
    const result = JSON.parse(clean);

    return res.status(200).json(result);

  } catch (error) {
    console.error('Error en /api/analizar:', error);
    return res.status(500).json({ error: 'Error interno del servidor' });
  }
}
