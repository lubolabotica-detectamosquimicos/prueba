// ============================================================
// LuBo La Botica — API: /api/analizar
// Analiza imágenes con Gemini IA y detecta químicos nocivos
// ============================================================

export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Método no permitido' });

  const apiKey = process.env.GEMINI_API_KEY;
  if (!apiKey) return res.status(500).json({ error: 'API key no configurada' });

  try {
    const { imageBase64, mediaType, userId, userName } = req.body;
    if (!imageBase64) return res.status(400).json({ error: 'Se requiere una imagen' });

    // ── BASE DE DATOS: QUÍMICOS NOCIVOS ──────────────────────────
    const DB_QUIMICOS = [
      // Alimentos
      "Bromato de potasio","Potassium bromate","Nitratos","Nitritos","Sodium nitrate","Sodium nitrite",
      "Aceites parcialmente hidrogenados","Partially hydrogenated","Trans fat","Grasas trans",
      "BHA","BHT","Butylated hydroxyanisole","Butylated hydroxytoluene",
      "Bisfenol A","BPA","Bisphenol",
      "Aluminio","Aluminum","Alum","Aluminosilicato",
      "Tartrazina","Tartrazine","E102","Yellow 5","FD&C Yellow 5",
      "Amarillo 5","Azul 1","Blue 1","Rojo 40","Red 40","FD&C Red 40",
      "Colorantes artificiales","Artificial colors","Artificial colours",
      "Perclorato","Perchlorate",
      "Glutamato monosódico","MSG","Monosodium glutamate","E621",
      "Eritrosina","Erythrosine","Red 3","E127",
      "Jarabe de maíz de alta fructosa","High fructose corn syrup","HFCS",
      "Propionato","Propionate","Calcium propionate","Sodium propionate","E282","E281",
      "Carragenina","Carrageenan","E407",
      "Diacetyl","Diacetilo","Acetyl propionyl","Acetoin",
      // Cosméticos / Ambos
      "PFOA","PFOS","Perfluorooctanoic","Perfluorooctane",
      "Benzoato de sodio","Sodium benzoate","E211","Benzoic acid",
      "Propylene glycol","Propilenglicol","E1520",
      "Peróxido de benzoilo","Benzoyl peroxide",
      "Plomo","Lead","Pb",
      "Mercurio","Mercury","Hg","Thimerosal",
      "Formaldehido","Formaldehyde","Formalin","DMDM Hydantoin","Quaternium-15",
      "Ftalatos","Phthalates","DBP","DEHP","DEP","Dibutyl phthalate",
      "Alquitrán de hulla","Coal tar","HC Blue","D&C",
      "Tolueno","Toluene",
      "1,4-dioxane","Dioxano","Dioxane","PEG-","Sodium laureth","Sodium myreth",
      "Triclosán","Triclosan","Triclocarban",
      "Aluminum chlorohydrate","Aluminum zirconium","Aluminium chlorohydrate",
      "DEA","TEA","MEA","Diethanolamine","Triethanolamine","Monoethanolamine",
      "Cocamide DEA","Lauramide DEA","Linoleamide DEA",
      "Resorcinol","Resorcin",
      "Parfum","Fragrance","Fragancia artificial",
      "Oxybenzone","Oxibenzona","Benzophenone-3","Avobenzone","Avobenzona",
      "Methylparaben","Metilparabeno","Ethylparaben","Etilparabeno",
      "Propylparaben","Propilparabeno","Butylparaben","Butilparabeno","Benzylparaben",
      "Polyethylene","Polietileno","Nylon","Microbeads","Microplásticos",
      "Sodium lauryl sulfate","SLS","Lauryl sulphate","Laurate sulphate",
      "PEG","PPG","Silicone","Dimethicone","Cyclopentasiloxane","Cyclomethicone",
      "Paraffinum liquidum","Paraffin","Mineral oil","Aceite mineral",
      "Sodium laureth sulfate","SLES","Ammonium lauryl","Ammonium laureth"
    ];

    const prompt = `Analiza esta imagen de una etiqueta de producto. Tu tarea principal es extraer la lista de ingredientes.

INSTRUCCIONES DETALLADAS:
1. Busca secciones que digan: "Ingredients:", "Ingredientes:", "INCI:", "Composición:", "Contiene:", "Componentes:", etc.
2. Lee TODO el texto visible aunque sea pequeño, en cualquier idioma.
3. Compara CADA ingrediente con esta lista de sustancias nocivas: ${DB_QUIMICOS.join(', ')}
4. Para ingredientes naturales busca: plantas, frutas, aceites vegetales, minerales naturales, extractos botánicos, etc.
5. Si un ingrediente nocivo aparece aunque sea UNO SOLO, lo marcas en coincidencias.

REGLA CRÍTICA DE SEMÁFORO ROJO:
- Si encuentras 1 o más ingredientes de la lista nociva con nocividad > 30, la clasificación es ROJA.
- Si el % de ingredientes nocivos respecto al total > 30%, también es ROJA.
- Ante la duda entre rojo y amarillo, SIEMPRE elige rojo.

RESPONDE SOLO CON ESTE JSON (sin explicaciones, sin markdown, sin texto adicional):
{
  "ingredientes": ["lista completa de todos los ingredientes encontrados"],
  "coincidencias": ["nombre exacto de la sustancia de la lista nociva que coincide"],
  "naturales": ["ingredientes claramente de origen natural"],
  "sinteticos_desconocidos": ["ingredientes sintéticos que NO están en la lista nociva"],
  "clasificacion_sugerida": "rojo|amarillo|verde",
  "porcentaje_nocivos": 0
}

