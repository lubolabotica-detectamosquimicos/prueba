{"error":"imagen_no_legible","ingredientes":[],"coincidencias":[],"naturales":[],"sinteticos_desconocidos":[],"clasificacion_sugerida":"verde","porcentaje_nocivos":0}`;

    // Intento 1: Flash rápido
    let result = await llamarGemini(apiKey, imageBase64, mediaType, prompt, 'gemini-1.5-flash');

    // Intento 2: Pro más potente si Flash falla
    if (!result || result.error === 'imagen_no_legible' || !result.ingredientes?.length) {
      console.log('Flash no leyó, intentando con Pro...');
      result = await llamarGemini(apiKey, imageBase64, mediaType, prompt, 'gemini-1.5-pro');
    }

    // Intento 3: Prompt simplificado
    if (!result || result.error === 'imagen_no_legible' || !result.ingredientes?.length) {
      console.log('Intentando con prompt simplificado...');
      const promptSimple = `Lee los ingredientes de esta etiqueta. Responde SOLO con JSON: {"ingredientes":["lista"],"coincidencias":[],"naturales":[],"sinteticos_desconocidos":[],"clasificacion_sugerida":"verde","porcentaje_nocivos":0}`;
      result = await llamarGemini(apiKey, imageBase64, mediaType, promptSimple, 'gemini-1.5-pro');
    }

    if (!result) {
      return res.status(200).json({
        error: 'imagen_no_legible',
        ingredientes: [], coincidencias: [], naturales: [],
        sinteticos_desconocidos: [], clasificacion_sugerida: 'verde', porcentaje_nocivos: 0
      });
    }

    // Registrar estadísticas si se provee userId (opcional)
    if (userId && result.ingredientes?.length > 0) {
      try {
        await registrarStats(userId, userName || 'Usuario', result);
      } catch (statsErr) {
        console.log('Stats no guardadas (no crítico):', statsErr.message);
      }
    }

    return res.status(200).json(result);

  } catch (error) {
    console.error('Error en /api/analizar:', error);
    return res.status(500).json({
      error: 'Error interno', detalle: error.message,
      ingredientes: [], coincidencias: [], naturales: [],
      sinteticos_desconocidos: [], clasificacion_sugerida: 'verde', porcentaje_nocivos: 0
    });
  }
}

async function llamarGemini(apiKey, imageBase64, mediaType, prompt, modelo) {
  try {
    const response = await fetch(
      `https://generativelanguage.googleapis.com/v1beta/models/${modelo}:generateContent?key=${apiKey}`,
      {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{
            parts: [
              { inline_data: { mime_type: mediaType || 'image/jpeg', data: imageBase64 } },
              { text: prompt }
            ]
          }],
          generationConfig: { temperature: 0.05, topP: 0.9, maxOutputTokens: 4096 },
          safetySettings: [
            { category: 'HARM_CATEGORY_HARASSMENT', threshold: 'BLOCK_NONE' },
            { category: 'HARM_CATEGORY_HATE_SPEECH', threshold: 'BLOCK_NONE' },
            { category: 'HARM_CATEGORY_SEXUALLY_EXPLICIT', threshold: 'BLOCK_NONE' },
            { category: 'HARM_CATEGORY_DANGEROUS_CONTENT', threshold: 'BLOCK_NONE' }
          ]
        })
      }
    );

    const data = await response.json();
    if (!response.ok || !data.candidates?.[0]?.content?.parts?.[0]?.text) {
      console.error(`Error ${modelo}:`, JSON.stringify(data));
      return null;
    }

    const text = data.candidates[0].content.parts[0].text;
    const clean = text.replace(/```json\s*/gi, '').replace(/```\s*/gi, '').replace(/^\s*[\r\n]/gm, '').trim();
    const jsonMatch = clean.match(/\{[\s\S]*\}/);
    if (!jsonMatch) return null;

    return JSON.parse(jsonMatch[0]);
  } catch (err) {
    console.error(`Error llamando ${modelo}:`, err.message);
    return null;
  }
}

// ── SISTEMA DE STATS: guarda en archivo JSON temporal en /tmp ─────────────────
// Para producción real, conectar a una base de datos (Supabase, PlanetScale, etc.)
async function registrarStats(userId, userName, resultado) {
  const fs = await import('fs/promises');
  const path = await import('path');
  const statsFile = '/tmp/lubo_stats.json';

  let stats = {};
  try {
    const raw = await fs.readFile(statsFile, 'utf8');
    stats = JSON.parse(raw);
  } catch {
    stats = {};
  }

  if (!stats[userId]) {
    stats[userId] = {
      nombre: userName,
      usos: 0,
      ingredientes_detectados: [],
      quimicos_encontrados: [],
      primera_vez: new Date().toISOString(),
      ultima_vez: new Date().toISOString()
    };
  }

  stats[userId].usos += 1;
  stats[userId].ultima_vez = new Date().toISOString();
  stats[userId].nombre = userName;

  // Acumular ingredientes únicos detectados
  const nuevosIngredientes = resultado.ingredientes || [];
  const nuevosQuimicos = resultado.coincidencias || [];

  nuevosIngredientes.forEach(ing => {
    if (!stats[userId].ingredientes_detectados.includes(ing)) {
      stats[userId].ingredientes_detectados.push(ing);
    }
  });

  nuevosQuimicos.forEach(q => {
    if (!stats[userId].quimicos_encontrados.includes(q)) {
      stats[userId].quimicos_encontrados.push(q);
    }
  });

  await fs.writeFile(statsFile, JSON.stringify(stats, null, 2));
}

// ============================================================
// LuBo La Botica — API: /api/stats
// Lee estadísticas de uso por usuario
// ============================================================
// NOTA: En Vercel serverless, /tmp no persiste entre invocaciones.
// Para producción real, usar Supabase, PlanetScale, Redis o similar.
// Esta implementación sirve como base para conectar cualquier BD.
// ============================================================

export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'GET, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');
  if (req.method === 'OPTIONS') return res.status(200).end();

  // Solo GET permitido
  if (req.method !== 'GET') return res.status(405).json({ error: 'Método no permitido' });

  // Clave simple de admin (cambiar en producción)
  const adminKey = req.query.key || '';
  if (adminKey !== (process.env.ADMIN_KEY || 'lubo2024admin')) {
    return res.status(401).json({ error: 'No autorizado' });
  }

  try {
    const fs = await import('fs/promises');
    const statsFile = '/tmp/lubo_stats.json';

    let stats = {};
    try {
      const raw = await fs.readFile(statsFile, 'utf8');
      stats = JSON.parse(raw);
    } catch {
      stats = {};
    }

    // Construir resumen
    const usuarios = Object.entries(stats).map(([id, data]) => ({
      userId: id,
      nombre: data.nombre,
      usos: data.usos,
      total_ingredientes_vistos: data.ingredientes_detectados?.length || 0,
      quimicos_encontrados: data.quimicos_encontrados?.length || 0,
      lista_quimicos: data.quimicos_encontrados || [],
      primera_vez: data.primera_vez,
      ultima_vez: data.ultima_vez
    }));

    return res.status(200).json({
      total_usuarios: usuarios.length,
      total_escaneos: usuarios.reduce((a, u) => a + u.usos, 0),
      usuarios: usuarios.sort((a, b) => b.usos - a.usos)
    });

  } catch (error) {
    return res.status(500).json({ error: 'Error leyendo stats', detalle: error.message });
  }
}
