// Simular variables de entorno si no existen
process.env.GOOGLE_API_KEY = process.env.GOOGLE_API_KEY || 'test-key-change-in-vercel';
process.env.ADMIN_KEY = process.env.ADMIN_KEY || 'lubo2024admin';

// URL de Google Sheets
const GOOGLE_SHEETS_CSV_URL = 'https://docs.google.com/spreadsheets/d/1QLmkn8hfq_vkBv3IcaJNRI_ly6f5HorZ/export?format=csv&gid=2117305422';

// Gemini API endpoint
const GEMINI_API_URL = 'https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent';

console.log('🚀 LuBo La Botica - API Server');
console.log('================================');
