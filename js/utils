/**
 * UTILS.JS
 * Funciones utilitarias reutilizables para toda la aplicación
 */

/**
 * Almacenar datos en localStorage con prefijo
 */
function guardarEnStorage(clave, valor) {
    try {
        const prefijo = 'lubo_';
        localStorage.setItem(prefijo + clave, JSON.stringify(valor));
        return true;
    } catch (error) {
        console.error('Error guardando en storage:', error);
        return false;
    }
}

/**
 * Obtener datos de localStorage
 */
function obtenerDelStorage(clave, porDefecto = null) {
    try {
        const prefijo = 'lubo_';
        const valor = localStorage.getItem(prefijo + clave);
        return valor ? JSON.parse(valor) : porDefecto;
    } catch (error) {
        console.error('Error leyendo storage:', error);
        return porDefecto;
    }
}

/**
 * Limpiar storage
 */
function limpiarStorage(clave = null) {
    try {
        const prefijo = 'lubo_';
        if (clave) {
            localStorage.removeItem(prefijo + clave);
        } else {
            // Limpiar todas las claves con prefijo
            const keys = Object.keys(localStorage);
            keys.forEach(key => {
                if (key.startsWith(prefijo)) {
                    localStorage.removeItem(key);
                }
            });
        }
        return true;
    } catch (error) {
        console.error('Error limpiando storage:', error);
        return false;
    }
}

/**
 * Generar ID único
 */
function generarID() {
    return `${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;
}

/**
 * Formatear fecha
 */
function formatearFecha(fecha = new Date()) {
    const opciones = {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
        hour: '2-digit',
        minute: '2-digit'
    };
    return new Date(fecha).toLocaleDateString('es-ES', opciones);
}

/**
 * Debounce - evitar llamadas repetidas
 */
function debounce(func, espera = 300) {
    let timeout;
    return function(...args) {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(this, args), espera);
    };
}

/**
 * Throttle - limitar llamadas
 */
function throttle(func, limite = 1000) {
    let inThrottle;
    return function(...args) {
        if (!inThrottle) {
            func.apply(this, args);
            inThrottle = true;
            setTimeout(() => inThrottle = false, limite);
        }
    };
}

/**
 * Deep clone de objeto
 */
function clonarObjeto(obj) {
    return JSON.parse(JSON.stringify(obj));
}

/**
 * Verificar si es dispositivo móvil
 */
function esMobil() {
    return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
}

/**
 * Verificar soporte de características
 */
function soporta(caracteristica) {
    const soportes = {
        localStorage: typeof Storage !== 'undefined',
        camera: navigator.mediaDevices && navigator.mediaDevices.getUserMedia,
        canvas: !!document.createElement('canvas').getContext,
        fetch: typeof fetch !== 'undefined',
        worker: typeof Worker !== 'undefined'
    };
    return soportes[caracteristica] || false;
}

/**
 * Realizar request con reintentos
 */
async function fetchConReintentos(url, opciones = {}, reintentos = 3) {
    for (let i = 0; i < reintentos; i++) {
        try {
            const respuesta = await fetch(url, opciones);
            if (respuesta.ok) {
                return respuesta;
            }
            if (i === reintentos - 1) throw new Error(`HTTP ${respuesta.status}`);
        } catch (error) {
            if (i === reintentos - 1) throw error;
            // Esperar antes de reintentar (exponential backoff)
            await new Promise(r => setTimeout(r, Math.pow(2, i) * 1000));
        }
    }
}

/**
 * Convertir imagen a base64
 */
function imagenABase64(file) {
    return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = reject;
        reader.readAsDataURL(file);
    });
}

/**
 * Redimensionar imagen
 */
function redimensionarImagen(base64, ancho, alto) {
    return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = ancho;
            canvas.height = alto;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, ancho, alto);
            resolve(canvas.toDataURL('image/jpeg', 0.9));
        };
        img.src = base64;
    });
}

/**
 * Comprimir imagen
 */
function comprimirImagen(base64, calidad = 0.8) {
    return new Promise((resolve) => {
        const img = new Image();
        img.onload = () => {
            const canvas = document.createElement('canvas');
            canvas.width = img.width;
            canvas.height = img.height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0);
            resolve(canvas.toDataURL('image/jpeg', calidad));
        };
        img.src = base64;
    });
}

/**
 * Mostrar notificación (toast)
 */
function mostrarNotificacion(mensaje, tipo = 'info', duracion = 3000) {
    const toast = document.createElement('div');
    toast.className = `toast toast-${tipo}`;
    toast.textContent = mensaje;
    toast.style.cssText = `
        position: fixed;
        bottom: 20px;
        right: 20px;
        padding: 16px 24px;
        background: ${tipo === 'error' ? '#ef4444' : tipo === 'success' ? '#53bb26' : '#3b82f6'};
        color: white;
        border-radius: 8px;
        font-size: 14px;
        z-index: 9999;
        animation: slideIn 0.3s ease-out;
    `;
    
    document.body.appendChild(toast);
    
    setTimeout(() => {
        toast.style.animation = 'slideOut 0.3s ease-out';
        setTimeout(() => toast.remove(), 300);
    }, duracion);
}

/**
 * Contar caracteres con límite
 */
function contarCaracteres(texto, limite) {
    const count = texto.length;
    return {
        actual: count,
        limite,
        disponibles: Math.max(0, limite - count),
        alcanzado: count >= limite
    };
}

/**
 * Validar email
 */
function validarEmail(email) {
    const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return regex.test(email);
}

/**
 * Validar URL
 */
function validarURL(url) {
    try {
        new URL(url);
        return true;
    } catch {
        return false;
    }
}

/**
 * Obtener parámetros de URL
 */
function obtenerParametrosURL() {
    const params = new URLSearchParams(window.location.search);
    const obj = {};
    params.forEach((valor, clave) => {
        obj[clave] = valor;
    });
    return obj;
}

/**
 * Esperar (promesa con timeout)
 */
function esperar(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
}

/**
 * Hacer log con timestamp
 */
function log(mensaje, datos = null) {
    const hora = new Date().toLocaleTimeString();
    console.log(`[${hora}] ${mensaje}`, datos || '');
}

/**
 * Estadísticas de uso
 */
function registrarEstadistica(evento, datos = {}) {
    const stats = obtenerDelStorage('estadisticas', {});
    
    if (!stats[evento]) {
        stats[evento] = [];
    }
    
    stats[evento].push({
        timestamp: new Date().toISOString(),
        datos,
        url: window.location.href
    });
    
    // Limitar a últimos 100 eventos
    if (stats[evento].length > 100) {
        stats[evento] = stats[evento].slice(-100);
    }
    
    guardarEnStorage('estadisticas', stats);
}

/**
 * Obtener estadísticas
 */
function obtenerEstadisticas() {
    return obtenerDelStorage('estadisticas', {});
}

/**
 * Exportar estadísticas como JSON
 */
function exportarEstadisticas() {
    const stats = obtenerEstadisticas();
    const json = JSON.stringify(stats, null, 2);
    const blob = new Blob([json], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `lubo-estadisticas-${Date.now()}.json`;
    a.click();
    URL.revokeObjectURL(url);
}

/**
 * Limpiar estadísticas antiguas (más de 30 días)
 */
function limpiarEstadisticasAntiguas(dias = 30) {
    const stats = obtenerDelStorage('estadisticas', {});
    const ahora = Date.now();
    const limite = dias * 24 * 60 * 60 * 1000;
    
    for (const evento in stats) {
        stats[evento] = stats[evento].filter(item => {
            const edad = ahora - new Date(item.timestamp).getTime();
            return edad < limite;
        });
    }
    
    guardarEnStorage('estadisticas', stats);
}

// Limpiar estadísticas al cargar
window.addEventListener('load', () => {
    limpiarEstadisticasAntiguas();
});
