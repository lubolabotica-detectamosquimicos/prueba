/**
 * SCANNER.JS - Herramienta de crop/recorte
 * Permite a usuarios dibujar un rectángulo sobre la imagen para seleccionar ingredientes
 */

let canvas, ctx;
let isDrawing = false;
let startX, startY;
let currentX = 0, currentY = 0;
let originalImage = null;

const config = {
    minWidth: 50,
    minHeight: 50,
    strokeColor: '#53bb26',
    strokeWidth: 3,
    fillColor: 'rgba(83, 187, 38, 0.1)',
    handleSize: 8
};

/**
 * Mostrar canvas para crop
 */
function mostrarCanvasParaCrop(imagenSrc) {
    canvas = document.getElementById('canvas');
    ctx = canvas.getContext('2d');
    
    const img = new Image();
    img.onload = () => {
        originalImage = img;
        
        // Ajustar canvas al tamaño de la imagen
        canvas.width = img.width;
        canvas.height = img.height;
        
        // Dibujar imagen
        ctx.drawImage(img, 0, 0);
        
        // Mostrar container canvas
        document.getElementById('canvasContainer').style.display = 'block';
        
        // Agregar listeners
        canvas.addEventListener('mousedown', iniciarCrop);
        canvas.addEventListener('mousemove', dibujarCrop);
        canvas.addEventListener('mouseup', finalizarCrop);
        canvas.addEventListener('mouseout', finalizarCrop);
        
        // Touch events para móvil
        canvas.addEventListener('touchstart', iniciarCropTouch);
        canvas.addEventListener('touchmove', dibujarCropTouch);
        canvas.addEventListener('touchend', finalizarCrop);
    };
    
    img.src = imagenSrc;
}

/**
 * Iniciar crop (mouse)
 */
function iniciarCrop(e) {
    const rect = canvas.getBoundingClientRect();
    startX = e.clientX - rect.left;
    startY = e.clientY - rect.top;
    isDrawing = true;
}

/**
 * Iniciar crop (touch)
 */
function iniciarCropTouch(e) {
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    startX = touch.clientX - rect.left;
    startY = touch.clientY - rect.top;
    isDrawing = true;
}

/**
 * Dibujar rectángulo mientras se arrastra (mouse)
 */
function dibujarCrop(e) {
    if (!isDrawing) return;
    
    const rect = canvas.getBoundingClientRect();
    currentX = e.clientX - rect.left;
    currentY = e.clientY - rect.top;
    
    redibujarsConSeleccion(startX, startY, currentX, currentY);
}

/**
 * Dibujar rectángulo mientras se arrastra (touch)
 */
function dibujarCropTouch(e) {
    if (!isDrawing) return;
    e.preventDefault();
    
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    currentX = touch.clientX - rect.left;
    currentY = touch.clientY - rect.top;
    
    redibujarsConSeleccion(startX, startY, currentX, currentY);
}

/**
 * Redibuja la imagen con la selección
 */
function redibujarsConSeleccion(x1, y1, x2, y2) {
    // Limpiar canvas
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    
    // Redib ujar imagen original
    if (originalImage) {
        ctx.drawImage(originalImage, 0, 0);
    }
    
    // Calcular ancho y alto
    const width = x2 - x1;
    const height = y2 - y1;
    
    // Dibujar rectángulo de selección
    ctx.fillStyle = config.fillColor;
    ctx.fillRect(x1, y1, width, height);
    
    ctx.strokeStyle = config.strokeColor;
    ctx.lineWidth = config.strokeWidth;
    ctx.strokeRect(x1, y1, width, height);
    
    // Dibujar handles en las esquinas
    dibujarHandles(x1, y1, x1 + width, y1 + height);
}

/**
 * Dibujar handles (puntos para redimensionar)
 */
function dibujarHandles(x1, y1, x2, y2) {
    const handles = [
        {x: x1, y: y1}, // top-left
        {x: x2, y: y1}, // top-right
        {x: x1, y: y2}, // bottom-left
        {x: x2, y: y2}  // bottom-right
    ];
    
    handles.forEach(handle => {
        ctx.fillStyle = config.strokeColor;
        ctx.fillRect(
            handle.x - config.handleSize/2,
            handle.y - config.handleSize/2,
            config.handleSize,
            config.handleSize
        );
        
        ctx.strokeStyle = 'white';
        ctx.lineWidth = 1;
        ctx.strokeRect(
            handle.x - config.handleSize/2,
            handle.y - config.handleSize/2,
            config.handleSize,
            config.handleSize
        );
    });
}

/**
 * Finalizar crop
 */
function finalizarCrop() {
    isDrawing = false;
}

/**
 * Confirmar selección - extraer imagen recortada
 */
function confirmarCrop() {
    if (!isDrawing && currentX > 0 && currentY > 0) {
        const width = Math.abs(currentX - startX);
        const height = Math.abs(currentY - startY);
        
        if (width < config.minWidth || height < config.minHeight) {
            alert(`Selecciona un área mínima de ${config.minWidth}x${config.minHeight}px`);
            return;
        }
        
        // Crear canvas temporal para recorte
        const tempCanvas = document.createElement('canvas');
        tempCanvas.width = width;
        tempCanvas.height = height;
        const tempCtx = tempCanvas.getContext('2d');
        
        const x = Math.min(startX, currentX);
        const y = Math.min(startY, currentY);
        
        if (originalImage) {
            tempCtx.drawImage(
                originalImage,
                x, y, width, height,
                0, 0, width, height
            );
        }
        
        // Actualizar imagen global
        imagenActual = tempCanvas.toDataURL('image/jpeg', 0.95);
        
        // Limpiar y ocultar canvas
        document.getElementById('canvasContainer').style.display = 'none';
        
        // Analizar imagen
        analizarImagen();
    } else {
        alert('Por favor dibuja una selección primero');
    }
}

/**
 * Limpiar/resetear
 */
function resetCrop() {
    isDrawing = false;
    startX = 0;
    startY = 0;
    currentX = 0;
    currentY = 0;
    
    if (originalImage) {
        ctx.drawImage(originalImage, 0, 0);
    }
}

/**
 * Exportar selección como imagen
 */
function exportarSeleccion() {
    const link = document.createElement('a');
    link.href = imagenActual;
    link.download = `lubo-ingredientes-${Date.now()}.jpg`;
    link.click();
}
