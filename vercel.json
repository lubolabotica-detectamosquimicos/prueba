{
  "version": 2,
  "builds": [
    {
      "src": "api/analizar.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/stats.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/analizar",
      "dest": "/api/analizar.js"
    },
    {
      "src": "/api/stats",
      "dest": "/api/stats.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
