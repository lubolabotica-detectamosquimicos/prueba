// Función para verificar si un ingrediente es natural
// Busca coincidencias parciales en múltiples idiomas
function esNatural(nombreIngrediente) {
  const n = nombreIngrediente.toLowerCase().trim();
  return DB_NATURALES.some(item => {
    const nombre = item.n.toLowerCase();
    // Coincidencia exacta o parcial
    if (n === nombre || nombre.includes(n) || n.includes(nombre)) return true;
    // Palabras clave del ingrediente natural (mínimo 4 chars para evitar falsos positivos)
    const palabras = nombre.split(/[\s,\/\(\)\-]+/).filter(p => p.length >= 4);
    return palabras.some(p => n.includes(p));
  });
}
