:root {
  --lime:  #cce510; --dark:  #441d1d;
  --green: #53bb26; --red:   #ff6161;
  --white: #ffffff; --bg:    #f8f8f0;
  --text:  #2a1a1a; --muted: #888888;
  --font:  'Fredoka', sans-serif;
  --sp-xs:.25rem; --sp-sm:.5rem; --sp-md:1rem;
  --sp-lg:1.5rem; --sp-xl:2rem; --sp-2xl:3rem;
  --r-sm:8px; --r-md:16px; --r-lg:24px; --r-full:9999px;
  --sh-sm:0 2px 8px rgba(68,29,29,.10);
  --sh-md:0 4px 20px rgba(68,29,29,.15);
  --sh-lg:0 8px 40px rgba(68,29,29,.20);
}
